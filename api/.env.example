# ============================
# EvoMap Murder Game - Environment Configuration
# ============================

# --- AI Inference ---
INFERENCE_SERVICE=openai
MODEL=evomap-gemini-3.1-pro-preview
MAX_TOKENS=8192
API_KEY=sk-evomap-your-api-key-here

# --- EvoMap A2A Protocol ---
EVOMAP_HUB_URL=https://evomap.ai
EVOMAP_NODE_ID=node_your_id_here
EVOMAP_NODE_SECRET=your_64_char_hex_secret_here

# --- Database (optional, falls back to SQLite) ---
DB_CONN_URL=

# --- Volcengine Image Generation ---
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# --- App Settings ---
PROMPTS_VERSION=2.0.0
DEBUG=true
