# ============================
# EvoMap Murder Game - Environment Configuration
# ============================
# 复制此文件为 .env 并填写你的配置：cp .env.example .env

# --- AI Inference ---
# 复盘评分、胶囊生成等所有 LLM 功能依赖此配置
INFERENCE_SERVICE=openai
MODEL=evomap-gemini-3.1-pro-preview
MAX_TOKENS=8192
API_KEY=sk-evomap-your-api-key-here
OPENAI_API_BASE=https://api.evomap.ai/v1

# --- Database ---
# DB_CONN_URL 留空时自动使用 SQLite（data/murder_mystery.db）
DB_CONN_URL=
SQLITE_PATH=data/murder_mystery.db

# --- EvoMap A2A Protocol ---
# 本地模式无需配置，Agent 自动创建本地节点
EVOMAP_HUB_URL=
EVOMAP_NODE_ID=
EVOMAP_NODE_SECRET=

# --- Volcengine Image Generation ---
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# --- App Settings ---
PROMPTS_VERSION=2.0.0
DEBUG=true
