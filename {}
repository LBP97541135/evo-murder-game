  font-family: "Crimson Pro", Georgia, serif;
}

/* Splash screen animations */
@keyframes splashTitleOut {
  to { opacity: 0; }
}
.splash-title-out {
  animation: splashTitleOut 2s ease-out forwards;
}

@keyframes splashCtaIn {
  from { opacity: 0; transform: translateY(28px); filter: drop-shadow(0 0 0px rgba(201, 42, 42, 0)); }
  to   { opacity: 1; transform: translateY(0);    filter: drop-shadow(0 0 18px rgba(201, 42, 42, 0.8)); }
}
.splash-cta-in {
  animation: splashCtaIn 1.2s ease-out forwards;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
    radial-gradient(circle at 50% 0%, rgba(198, 106, 79, 0.12), transparent 28%),
    radial-gradient(circle at 0% 100%, rgba(100, 64, 52, 0.16), transparent 28%);
  background-size: 48px 48px, 48px 48px, 100% 100%, 100% 100%;
  mix-blend-mode: screen;
  opacity: 0.55;
}

body::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.04), transparent 18%, transparent 82%, rgba(255, 255, 255, 0.03)),
    radial-gradient(circle at 50% 50%, transparent 55%, rgba(0, 0, 0, 0.22) 100%);
