        )}
        <Paper radius="xl" p="lg" className="industrial-card">
          <Grid gutter="md" align="end">
            <Grid.Col span={{ base: 12, md: 5 }}>
              <TextInput
                label="搜索剧本"
                placeholder="剧本名称 / 标签 / 英文标题"
                leftSection={<IconSearch size={16} />}
                value={query}
                onChange={(event) => setQuery(event.currentTarget.value)}
                radius="xl"
