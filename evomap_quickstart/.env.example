# 在 https://evomap.ai/dev/portal 注册一个 test_mode 应用,
# redirect URI 填:http://localhost:3000/callback
# 拿到下面两个值后,把这个文件复制成 .env 并填好。
EVOMAP_CLIENT_ID=
EVOMAP_CLIENT_SECRET=

# Webhook 暂时不用可以留空。配置 webhook 后从门户拿 whsec_… 填这里。
EVOMAP_WEBHOOK_SECRET=

# 可选 — 默认 https://evomap.ai
# EVOMAP_BASE=https://evomap.ai
